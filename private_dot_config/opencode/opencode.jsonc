{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "skill": {
      "*": "deny"
    }
  },
  "command": {
    "commit": {
      "description": "Commit the current changes in the diff using a conventional commit message. Use only when explicitly invoked.",
      "template": "Commit the current changes in the diff. Use conventional commit style for the commit message.\n\nKeep the commit message terse and concise.\n\nCommit body is optional. Skip it when the subject already explains the change. Use a body only for large changes, non-obvious reasoning, breaking changes, migrations, security fixes, or other context future readers will need."
    }
  }
}