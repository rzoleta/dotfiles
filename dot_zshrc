# cd into selected directory
cdf() {
  local dir
  dir=$(fd --type d --hidden --exclude .git | fzf) && cd "$dir"
}

fo() {
  if [[ $# -eq 0 ]]; then
    print -u2 "usage: fo <opener> [args...]"
    return 1
  fi

  local opener="$1"
  shift

  local file
  file=$(
    fd --type f --hidden --follow --exclude .git |
      fzf --preview 'bat --color=always --style=numbers --line-range=:200 {}'
  ) || return

  "$opener" "$@" "$file"
}

